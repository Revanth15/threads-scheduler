# =============================================
# BusSing Threads Scheduler — Environment Config
# =============================================

# --- Threads API ---
# Get these from: https://developers.facebook.com/apps/
THREADS_APP_ID=your_app_id_here
THREADS_APP_SECRET=your_app_secret_here
THREADS_ACCESS_TOKEN=your_long_lived_access_token_here
THREADS_USER_ID=your_threads_user_id_here

# --- OpenRouter AI ---
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Recommended for structured text generation: openai/gpt-4o-mini
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_REASONING_MAX_TOKENS=256

# --- Posting Schedule (SGT) ---
# 5 slots per day. Set hour to -1 to disable a slot.
TIMEZONE=Asia/Singapore

SLOT_1_HOUR=7
SLOT_1_MINUTE=30
SLOT_1_TYPE=morning_commute

SLOT_2_HOUR=10
SLOT_2_MINUTE=0
SLOT_2_TYPE=midday

SLOT_3_HOUR=12
SLOT_3_MINUTE=30
SLOT_3_TYPE=lunch

SLOT_4_HOUR=17
SLOT_4_MINUTE=30
SLOT_4_TYPE=evening_commute

SLOT_5_HOUR=21
SLOT_5_MINUTE=0
SLOT_5_TYPE=night

MIN_POSTS_PER_DAY=3
MAX_POSTS_PER_DAY=5

# --- Content ---
CONTENT_FILE=content.md
MAX_POST_LENGTH=500

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./threads_scheduler.db

# --- App ---
SECRET_KEY=change-me-to-a-random-string
DEBUG=false
PORT=8000
